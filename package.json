{
  "name": "gspeak",
  "version": "0.0.1",
  "description": "Google Text to Speech — a modern TypeScript rewrite of gtts with zero deprecated dependencies",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "bin": {
    "gspeak": "./dist/bin/gspeak.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "tsc -p .",
    "prepublishOnly": "npm run build",
    "lint": "eslint src/**/*.ts bin/**/*.ts",
    "test": "mocha --timeout 30000 -r ts-node/register \"tests/**/*.test.ts\""
  },
  "keywords": [
    "google",
    "tts",
    "text-to-speech",
    "gtts",
    "gspeak",
    "speech",
    "audio",
    "mp3",
    "typescript"
  ],
  "author": "Qasim Ali",
  "license": "MIT",
  "dependencies": {
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.0",
    "@types/node": "^22.0.0",
    "@types/yargs": "^17.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "mocha": "^11.0.0",
    "rimraf": "^6.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0"
  },
  "publishConfig": {
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GlobalTechInfo/gspeak.git"
  },
  "bugs": {
    "url": "https://github.com/GlobalTechInfo/gspeak/issues"
  },
  "homepage": "https://github.com/GlobalTechInfo/gspeak#readme"
}
